<?xml version="1.0" encoding="utf-8"?> 
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup Label="Globals">
    <!-- (c) https://stackoverflow.com/a/44060441/536172 -->
    <VCProjectUpgraderObjectName>NoUpgrade</VCProjectUpgraderObjectName>
  </PropertyGroup>
  <PropertyGroup Label="Configuration">
    <!-- MultiByte charset isn't supported -->
    <!-- Unicode charset may cause problems in old zlib (before 1.2.11) -->
    <CharacterSet>Unicode</CharacterSet>
    <PlatformToolset>v143</PlatformToolset> <!-- VS2022 -->
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Debug'" Label="Configuration">
    <UseDebugLibraries>true</UseDebugLibraries>
    <WholeProgramOptimization>false</WholeProgramOptimization>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'" Label="Configuration">
    <UseDebugLibraries>false</UseDebugLibraries>
    <WholeProgramOptimization>true</WholeProgramOptimization>
  </PropertyGroup>
  <Import Project="user\_Platform.props" Condition="exists('user\_Platform.props')"/>
</Project>
